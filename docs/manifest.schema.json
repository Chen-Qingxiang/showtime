{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chen-qingxiang.github.io/showtime/docs/manifest.schema.json",
  "title": "ShowTime project manifest",
  "description": "Manifest for a static ShowTime .showtime.zip research project.",
  "type": "object",
  "required": ["format", "version", "project", "layers"],
  "properties": {
    "format": { "const": "showtime-project" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$" },
    "project": { "$ref": "#/$defs/project" },
    "groups": { "type": "array", "items": { "$ref": "#/$defs/group" } },
    "layers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/layer" } },
    "timeRange": { "$ref": "#/$defs/timeRange" },
    "initialView": { "$ref": "#/$defs/timeRange" },
    "lodMode": { "enum": ["auto", "manual"] },
    "views": { "type": "array", "items": { "$ref": "#/$defs/savedView" } },
    "bookmarks": { "type": "array", "items": { "$ref": "#/$defs/bookmark" } },
    "probes": { "type": "array", "maxItems": 2, "items": { "$ref": "#/$defs/probe" } },
    "filters": { "type": "object" },
    "search": { "$ref": "#/$defs/search" },
    "metadata": {
      "type": "object",
      "properties": {
        "events": { "type": "string" },
        "sources": { "type": "string" },
        "references": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "topic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "group": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 0 },
        "collapsed": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "dimmed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "layer": {
      "type": "object",
      "required": ["id", "name", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "pattern": "\\.csv$" },
        "role": { "enum": ["primary", "context", "anchor", "background"] },
        "groupId": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "color": { "type": "string" },
        "visible": { "type": "boolean" },
        "dimmed": { "type": "boolean" },
        "sourceKind": { "type": "string" },
        "lod": { "$ref": "#/$defs/lod" }
      },
      "additionalProperties": true
    },
    "lod": {
      "type": "object",
      "required": ["key", "level"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "level": { "enum": ["overview", "detailed"] },
        "switchSpan": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "timeRange": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "number" },
        "end": { "type": "number" }
      },
      "additionalProperties": true
    },
    "probe": {
      "type": "object",
      "required": ["id", "time"],
      "properties": {
        "id": { "type": "string" },
        "time": { "type": "number" },
        "label": { "type": "string" },
        "precision": { "enum": ["year", "month", "date", "hour", "minute", "second"] },
        "windowMode": { "enum": ["exact", "1y", "5y", "10y", "custom"] },
        "customBefore": { "type": "number", "minimum": 0 },
        "customAfter": { "type": "number", "minimum": 0 },
        "pinned": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "search": {
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "scope": { "enum": ["all", "visible", "current", "primary", "background"] },
        "dimUnmatched": { "type": "boolean" },
        "onlyMatches": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "savedView": {
      "type": "object",
      "required": ["id", "name", "view"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "view": { "$ref": "#/$defs/timeRange" },
        "layers": { "type": "array", "items": { "type": "object" } },
        "groups": { "type": "array", "items": { "type": "object" } },
        "filters": { "type": "object" },
        "search": { "$ref": "#/$defs/search" },
        "probes": { "type": "array", "maxItems": 2, "items": { "$ref": "#/$defs/probe" } },
        "selectedEventId": { "type": ["string", "null"] },
        "lodMode": { "enum": ["auto", "manual"] }
      },
      "additionalProperties": true
    },
    "bookmark": {
      "type": "object",
      "required": ["id", "name", "time"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "time": { "type": "number" },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
